{
  "expo": {
    "name": "Side Quest Slayer",
    "slug": "side-quest-slayer",
    "scheme": "sidequestslayer",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Side Quest Slayer uses your camera to capture daily proof of your progress.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Side Quest Slayer uses your selected photos to add proof moments and suggest when they happened.",
          "microphonePermission": false
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Side Quest Slayer uses your selected photos to add proof moments and suggest when they happened.",
          "savePhotosPermission": false,
          "granularPermissions": [
            "photo"
          ]
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      "expo-font"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sidequestslayer.app",
      "buildNumber": "3",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.sidequestslayer.app"
        ]
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Side Quest Slayer uses your camera to capture daily proof of your progress.",
        "NSPhotoLibraryUsageDescription": "Side Quest Slayer uses your selected photos to add proof moments and suggest when they happened.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.sidequestslayer.app",
      "allowBackup": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "cb4c8ffe-5546-443b-90dc-a0f90ef20cb3"
      }
    },
    "owner": "mbello498"
  }
}
